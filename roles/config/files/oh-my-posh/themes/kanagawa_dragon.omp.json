{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "os": "#c5c9c5",
    "closer": "p:os",
    "pink": "#a292a3",
    "violet": "#8992a7",
    "blue": "#8ba4b0",
    "red": "#c4746e",
    "yellow": "#c4b28a",
    "green": "#87a987"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:yellow",
          "properties": {
            "folder_icon": "..\ue5fe..",
            "home_icon": "~",
            "style": "agnoster_full"
          },
          "style": "plain",
          "template": "\udb80\udecb {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "p:violet",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": true,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "template": "{{ .HEAD }} <p:red>({{.ShortHash}})",
          "style": "plain",
          "type": "git"
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "type": "prompt",
      "segments": [
        {
          "foreground": "p:os",
          "style": "plain",
          "template": "{{.Icon}} ",
          "type": "os"
        },
        {
          "style": "plain",
          "foreground": "p:green",
          "template": "->",
          "type": "text"
        }
      ]
    }
  ],
  "enable_cursor_positioning": true,
  "final_space": true,
  "version": 2
}
