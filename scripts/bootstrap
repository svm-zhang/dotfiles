#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
readonly ANSIBLE_CONFIG_FILE="${REPO_ROOT}/ansible/ansible.cfg"
readonly ANSIBLE_PLAYBOOK="${REPO_ROOT}/ansible/playbooks/site.yml"
export ANSIBLE_CONFIG="${ANSIBLE_CONFIG_FILE}"

MODE="run"

if [[ "$(uname -s)" == "Darwin" && "${LC_ALL:-}" == "C.UTF-8" ]]; then
  unset LC_ALL
  export LANG=C
  export LC_CTYPE=C
elif ! locale >/dev/null 2>&1; then
  unset LC_ALL
  export LANG=C
  export LC_CTYPE=C
fi

usage() {
  cat <<'USAGE'
Usage:
  scripts/bootstrap [--check] [--help]

Prepare the stage-0 environment needed to run this repository's Ansible
playbook. Bootstrap does not install the full tool inventory and does not
deploy dotfiles.

Options:
  --check   Report whether stage-0 requirements are present; do not install.
  --help    Show this help text.
USAGE
}

log() {
  printf '[bootstrap] %s\n' "$*"
}

warn() {
  printf '[bootstrap] warning: %s\n' "$*" >&2
}

die() {
  printf '[bootstrap] error: %s\n' "$*" >&2
  exit 1
}

have() {
  command -v "$1" >/dev/null 2>&1
}

run_cmd() {
  log "+ $*"
  "$@"
}

brew_install() {
  log "+ brew install $*"
  HOMEBREW_NO_AUTO_UPDATE=1 HOMEBREW_NO_INSTALL_CLEANUP=1 brew install "$@"
}

setup_homebrew_env() {
  local brew_path

  if have brew; then
    eval "$(brew shellenv)"
    return 0
  fi

  for brew_path in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "${brew_path}" ]]; then
      eval "$("${brew_path}" shellenv)"
      return 0
    fi
  done

  return 1
}

install_homebrew() {
  log "+ install Homebrew with the official installer"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  setup_homebrew_env || die "Homebrew installed, but brew could not be found in the current shell"
}

run_root() {
  if [[ "$(id -u)" -eq 0 ]]; then
    run_cmd "$@"
  elif have sudo; then
    run_cmd sudo "$@"
  else
    die "root privileges are required, but sudo is not available"
  fi
}

parse_args() {
  if [[ "$#" -eq 0 ]]; then
    return
  fi

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --check)
        MODE="check"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        usage >&2
        die "unknown argument: $1"
        ;;
    esac
    shift
  done
}

detect_os() {
  case "$(uname -s)" in
    Darwin)
      printf 'macos\n'
      ;;
    Linux)
      if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        case "${ID:-}" in
          ubuntu|debian)
            printf 'ubuntu\n'
            ;;
          *)
            die "unsupported Linux distribution: ${ID:-unknown}"
            ;;
        esac
      else
        die "cannot detect Linux distribution without /etc/os-release"
      fi
      ;;
    *)
      die "unsupported OS: $(uname -s)"
      ;;
  esac
}

check_command() {
  local name="$1"
  if have "${name}"; then
    log "found ${name}: $(command -v "${name}")"
    return 0
  fi

  warn "missing ${name}"
  return 1
}

require_file() {
  local path="$1"
  [[ -f "${path}" ]] || die "required file is missing: ${path}"
}

bootstrap_macos() {
  log "detected macOS"

  if xcode-select -p >/dev/null 2>&1; then
    log "Command Line Tools path: $(xcode-select -p)"
  elif [[ "${MODE}" == "check" ]]; then
    warn "Command Line Tools are missing"
  else
    warn "Command Line Tools are missing; macOS may open an installer prompt"
    run_cmd xcode-select --install
    die "rerun bootstrap after Command Line Tools installation completes"
  fi

  if ! setup_homebrew_env; then
    if [[ "${MODE}" == "check" ]]; then
      warn "Homebrew is missing"
      return 1
    fi
    install_homebrew
  fi
  log "found brew: $(command -v brew)"

  local missing=0

  if ! check_command ansible-playbook; then
    missing=1
    if [[ "${MODE}" == "run" ]]; then
      brew_install ansible
      hash -r
    fi
  fi

  if [[ "${MODE}" == "check" && "${missing}" -ne 0 ]]; then
    return 1
  fi
}

bootstrap_ubuntu() {
  log "detected Ubuntu/Debian"

  local base_packages=(
    sudo
    curl
    wget
    ca-certificates
    software-properties-common
  )

  local missing_base=()
  local missing=()
  local pkg
  local status
  local ansible_ppa_present=0

  for pkg in "${base_packages[@]}"; do
    status="$(dpkg-query -W -f='${Status}' "${pkg}" 2>/dev/null || true)"
    if [[ "${status}" == "install ok installed" ]]; then
      log "package installed: ${pkg}"
    else
      warn "package missing: ${pkg}"
      missing_base+=("${pkg}")
      missing+=("${pkg}")
    fi
  done

  status="$(dpkg-query -W -f='${Status}' ansible 2>/dev/null || true)"
  if [[ "${status}" == "install ok installed" ]]; then
    log "package installed: ansible"
  else
    warn "package missing: ansible"
    missing+=("ansible")
  fi

  if grep -Rqs "ppa.launchpadcontent.net/ansible/ansible/ubuntu" /etc/apt/sources.list /etc/apt/sources.list.d 2>/dev/null ||
     grep -Rqs "ppa.launchpad.net/ansible/ansible/ubuntu" /etc/apt/sources.list /etc/apt/sources.list.d 2>/dev/null; then
    ansible_ppa_present=1
    log "Ansible PPA is configured"
  else
    warn "Ansible PPA is missing"
    missing+=("ansible-ppa")
  fi

  if [[ "${MODE}" == "check" ]]; then
    [[ "${#missing[@]}" -eq 0 ]] || return 1
    return 0
  fi

  export DEBIAN_FRONTEND=noninteractive

  if [[ "${#missing_base[@]}" -gt 0 ]]; then
    run_root apt-get update
    run_root apt-get install -y --no-install-recommends "${missing_base[@]}"
  fi

  if [[ "${ansible_ppa_present}" -ne 1 ]]; then
    run_root add-apt-repository --yes --update ppa:ansible/ansible
  elif [[ " ${missing[*]} " == *" ansible "* ]]; then
    run_root apt-get update
  fi

  if [[ " ${missing[*]} " == *" ansible "* || "${ansible_ppa_present}" -ne 1 ]]; then
    run_root apt-get install -y --no-install-recommends ansible
  fi
}

verify_ansible() {
  local os="$1"
  local ansible_inventory

  case "${os}" in
    macos)
      ansible_inventory="${REPO_ROOT}/ansible/inventory/local_macos.yml"
      ;;
    ubuntu)
      ansible_inventory="${REPO_ROOT}/ansible/inventory/local_ubuntu.yml"
      ;;
    *)
      die "unsupported detected OS: ${os}"
      ;;
  esac

  require_file "${ANSIBLE_CONFIG_FILE}"
  require_file "${ansible_inventory}"
  require_file "${ANSIBLE_PLAYBOOK}"

  check_command ansible-playbook || die "ansible-playbook is required"
  run_cmd ansible-playbook --version
  run_cmd ansible-playbook -i "${ansible_inventory}" "${ANSIBLE_PLAYBOOK}" --syntax-check
}

main() {
  parse_args "$@"

  local os
  os="$(detect_os)"

  case "${os}" in
    macos)
      bootstrap_macos
      ;;
    ubuntu)
      bootstrap_ubuntu
      ;;
    *)
      die "unsupported detected OS: ${os}"
      ;;
  esac

  verify_ansible "${os}"
  log "stage-0 bootstrap ${MODE} completed"
}

main "$@"
